words <- df %>% filter(Item_type == "word")
words %>%
summarise(
mean_freq = mean(Lg10SUBTLEX_US),
sd_freq   = sd(Lg10SUBTLEX_US),
min_freq  = min(Lg10SUBTLEX_US),
max_freq  = max(Lg10SUBTLEX_US),
n = n()
)
words <- df %>% filter(Condition == "word")
words %>%
summarise(
mean_freq = mean(Lg10SUBTLEX_US),
sd_freq   = sd(Lg10SUBTLEX_US),
min_freq  = min(Lg10SUBTLEX_US),
max_freq  = max(Lg10SUBTLEX_US),
n = n()
)
words <- df %>% filter(Condition == "word")
words %>%
summarise(
mean_freq = mean(Lg10SUBTLEX_US),
sd_freq   = sd(Lg10SUBTLEX_US),
min_freq  = min(Lg10SUBTLEX_US),
max_freq  = max(Lg10SUBTLEX_US),
n = n()
)
# outlier detection
q <- quantile(words$Lg10SUBTLEX_US, probs = c(.25, .75))
iqr <- q[2] - q[1]
lower <- q[1] - 1.5 * iqr
upper <- q[2] + 1.5 * iqr
words %>% filter(Lg10SUBTLEX_US < lower | Lg10SUBTLEX_US > upper)
# frequency plot
p_freq <- ggplot(words, aes(x = Lg10SUBTLEX_US)) +
geom_histogram(bins = 20, fill = "steelblue", color = "black") +
theme_minimal() +
labs(title = "Frequency Distribution (Words Only)",
x = "Log10 SUBTLEX-US Frequency")
p_freq
# export plot (pdf & png)
ggsave("frequency_distribution.pdf", p_freq, width = 6, height = 4)
ggsave("frequency_distribution.png", p_freq, width = 6, height = 4, dpi = 300)
