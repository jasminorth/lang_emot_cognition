library(tidyverse)
knitr::opts_chunk$set(
echo = TRUE,
message = FALSE,
warning = FALSE
)
df <- read_delim("dataset_experiment_stimuli.csv", delim = ";")
knitr::opts_chunk$set(echo = TRUE)
df %>%
group_by(Item_type) %>%
summarise(
mean_length = mean(Length),
sd_length   = sd(Length),
min_length  = min(Length),
max_length  = max(Length),
n = n()
)
knitr::opts_chunk$set(echo = TRUE)
t.test(Length ~ Item_type, data = df)
t.test(Length ~ Item_type, data = df)
knitr::opts_chunk$set(echo = TRUE)
t.test(Length ~ Condition, data = df)
knitr::opts_chunk$set(echo = TRUE)
df %>%
group_by(Condition) %>%
summarise(
mean_length = mean(Length),
sd_length   = sd(Length),
min_length  = min(Length),
max_length  = max(Length),
n = n()
)
knitr::opts_chunk$set(echo = TRUE)
t.test(Length ~ Condition, data = df)
knitr::opts_chunk$set(echo = TRUE)
p_length
p_length <- ggplot(df, aes(x = Length, fill = Item_type)) +
geom_histogram(position = "identity", alpha = 0.5, bins = 10) +
theme_minimal() +
labs(title = "Length Distribution: Words vs Nonwords")
p_length
