---
API: 3
OpenSesame: 4.1.9
Platform: nt
---
set width 1024
set title Experiment_both_feedback_conditions
set subject_parity even
set subject_nr 0
set start experiment
set sound_sample_size -16
set sound_freq 48000
set sound_channels 2
set sound_buf_size 1024
set sampler_backend psycho
set round_decimals 2
set mouse_backend psycho
set keyboard_backend psycho
set height 768
set fullscreen no
set form_clicks no
set foreground white
set font_underline no
set font_size 18
set font_italic False
set font_family mono
set font_bold False
set experiment_path "C:\\Users\\jasmi\\Documents\\Master\\2_SS26\\Sprache, Emotion und Kognition\\Project\\experiment"
set disable_garbage_collection False
set description "The main experiment item"
set color_backend psycho
set clock_backend psycho
set canvas_backend psycho
set background "#000000"

define keyboard_response break_keyboard_response
	set timeout infinite
	set flush yes
	set event_type keypress
	set duration keypress
	set description "Collects keyboard responses"
	set allowed_responses space

define sketchpad break_no_feedback
	set duration 0
	set description "Displays stimuli"
	draw textline center=1 color=white font_bold=no font_family=mono font_italic=no font_size=30 html=yes show_if=True text="End of block.<br /><br /><br /><br />Take a break until you feel ready to continue.<br /><br />Press the space bar to complete the rest of the experiment." x=0 y=0 z_index=0

define sketchpad break_with_feedback
	set duration 0
	set description "Displays stimuli"
	draw textline center=1 color=white font_bold=no font_family=mono font_italic=no font_size=30 html=yes show_if=True text="End of block.<br /><br />Your accuracy was [acc]%.<br /><br />Take a break until you feel ready to continue.<br /><br />Press the space bar to complete the rest of the experiment." x=0 y=0 z_index=0

define sequence breaking_sequence
	set flush_keyboard yes
	set description "Runs a number of items in sequence"
	run break_no_feedback "[subject_parity] = even"
	run break_with_feedback "[subject_parity] = odd"
	run break_keyboard_response True
	run new_1_reset_feedback True

define feedback end_of
	set reset_variables yes
	set duration 0
	set description "Provides feedback to the participant"
	draw textline center=1 color=white font_bold=no font_family=mono font_italic=no font_size=18 html=yes show_if=True text="" x=-96 y=-160 z_index=0
	draw textline center=1 color=white font_bold=no font_family=mono font_italic=no font_size=30 html=yes show_if=True text="Congratulations, you reached the end of the experiment!<br /><br />Your accuracy was [acc]%.<br /><br />Thank you for your participation. Please press the space bar to end the experiment." x=0 y=0 z_index=0

define keyboard_response end_of_exp_keyboard_response
	set timeout infinite
	set flush yes
	set event_type keypress
	set duration keypress
	set description "Collects keyboard responses"
	set allowed_responses space

define feedback end_of_exp_no_feedback
	set reset_variables yes
	set duration 0
	set description "Provides feedback to the participant"
	draw textline center=1 color=white font_bold=no font_family=mono font_italic=no font_size=18 html=yes show_if=True text="" x=-96 y=-160 z_index=0
	draw textline center=1 color=white font_bold=no font_family=mono font_italic=no font_size=30 html=yes show_if=True text="Congratulations, you reached the end of the experiment!<br /><br /><br /><br />Thank you for your participation. Please press the space bar to end the experiment." x=0 y=0 z_index=0

define sketchpad end_of_exp_no_feedbackkk
	set duration 0
	set description "Displays stimuli"
	draw textline center=1 color=white font_bold=no font_family=mono font_italic=no font_size=30 html=yes show_if=True text="Congratulations, you reached the end of the experiment!<br /><br /><br /><br />Thank you for your participation. Please press the space bar to end the experiment." x=0 y=0 z_index=0

define sketchpad end_of_exp_with_feedbackkk
	set duration 0
	set description "Displays stimuli"
	draw textline center=1 color=white font_bold=no font_family=mono font_italic=no font_size=30 html=yes show_if=True text="Congratulations, you reached the end of the experiment!<br /><br />Your accuracy was [acc]%.<br /><br />Thank you for your participation. Please press the space bar to end the experiment." x=0 y=0 z_index=0

define keyboard_response end_of_prac_keyboard_response
	set timeout infinite
	set flush yes
	set event_type keypress
	set duration keypress
	set description "Collects keyboard responses"
	set allowed_responses space

define sketchpad end_of_prac_no_feedback
	set duration 0
	set description "Displays stimuli"
	draw textline center=1 color=white font_bold=no font_family=mono font_italic=no font_size=30 html=yes show_if=True text="You have reached the end of the practice run.<br /><br /><br /><br />If any questions remained, please ask them now.<br /><br />Otherwise, we can start our experiment! Please press the space bar to start." x=0 y=0 z_index=0

define sketchpad end_of_prac_with_feedback
	set duration 0
	set description "Displays stimuli"
	draw textline center=1 color=white font_bold=no font_family=mono font_italic=no font_size=30 html=yes show_if=True text="You have reached the end of the practice run.<br /><br />Your accuracy was [var.practice_acc]%<br /><br />If any questions remained, please ask them now.<br /><br />Otherwise, we can start our experiment! Please press the space bar to start." x=0 y=0 z_index=0

define feedback end_of_prac_with_feedbackk
	set reset_variables yes
	set duration 0
	set description "Provides feedback to the participant"
	draw textline center=1 color=white font_bold=no font_family=mono font_italic=no font_size=18 html=yes show_if=True text="" x=-96 y=-160 z_index=0
	draw textline center=1 color=white font_bold=no font_family=mono font_italic=no font_size=30 html=yes show_if=True text="You have reached the end of the practice run.<br /><br />Your accuracy was [acc]%<br /><br />If any questions remained, please ask them now.<br /><br />Otherwise, we can start our experiment! Please press the space bar to start." x=0 y=0 z_index=0

define feedback end_of_practice_no_feedback
	set reset_variables yes
	set duration 0
	set description "Provides feedback to the participant"
	draw textline center=1 color=white font_bold=no font_family=mono font_italic=no font_size=18 html=yes show_if=True text="" x=-96 y=-160 z_index=0
	draw textline center=1 color=white font_bold=no font_family=mono font_italic=no font_size=30 html=yes show_if=True text="You have reached the end of the practice run.<br /><br /><br /><br />If any questions remained, please ask them now.<br /><br />Otherwise, we can start our experiment! Please press the space bar to start." x=0 y=0 z_index=0

define sequence experiment
	set flush_keyboard yes
	set description "Runs a number of items in sequence"
	run participants True
	run instructions True
	run instructions_keyboard_response True
	run practice_loop True
	run reset_trial_counter True
	run end_of_practice_no_feedback "[subject_parity] = even"
	run end_of_prac_with_feedbackk "[subject_parity] = odd"
	run end_of_prac_keyboard_response True
	run experimental_loop True
	run end_of_exp_no_feedback True
	run end_of True
	run end_of_exp_keyboard_response True

define loop experimental_loop
	set source_file ""
	set source table
	set repeat 1
	set order random
	set description "Repeatedly runs another item"
