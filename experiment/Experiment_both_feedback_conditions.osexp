define inline_script reset_trial_counter
	set description "Executes Python code"
	___run__
	exp.items["trial_sequence"].count = -1
	
	# Notiz: habe im Code was geändert, das Folgende gilt nicht mehr... # TODO: löschen
	# setze die Variable Block auf 1 für den ersten Durchlauf
	# var.Block = 1
	__end__
	set _prepare ""

define sketchpad stimulus
	set duration 0
	set description "Displays stimuli"
	draw textline center=1 color=white font_bold=no font_family=mono font_italic=no font_size=60 html=yes show_if=True text="[Stimulus]" x=0 y=0 z_index=0

define keyboard_response stimulus_keyboard_response
	set timeout 2500
	set flush yes
	set event_type keypress
	set duration keypress
	set description "Collects keyboard responses"
	set allowed_responses "j;f"

define sequence trial_sequence
	set flush_keyboard yes
	set description "Runs a number of items in sequence"
	run fixation True
	run stimulus True
	run stimulus_keyboard_response True
	run variables True
	run logger True
	run breaking_sequence "[count_trial_sequence] = 30 or [count_trial_sequence] = 60 or [count_trial_sequence] = 90 or [count_trial_sequence] = 120 or [count_trial_sequence] = 150"

define inline_script variables
	set description "Executes Python code"
	___run__
	var.RT = var.response_time_stimulus_keyboard_response
	var.Accuracy = var.correct
	
	# Feedback Bedingungen:
	# Probanden mit geraden IDs -> kein Feedback
	# Probanden mit ungeraden IDs -> Feedback
	# "%" bedeutet "modulo" (Ganzzahlteilung)
	# wenn die ProbandenID ganzzahl-geteilt durch 2 eine 0 ergibt,
	# dann ist es eine gerade Zahl, also kein Feedback
	# wenn die Ganzzahlteilung eine 1 ergibt, dann ist es eine
	# ungerade Zahl, also Feedback
	# Bonus: beim Programmieren heißt 1 "wahr"/True
	# und 0 "falsch"/False, das ist also ein netter Trick :)
	var.Feedback = int(var.Participant) % 2
	
	# erhöhe die Blockvariable nach jeder Runde um 1
	# eine Runde besteht aus 30 items, das heißt immer wenn die Ganzzahl-
	# teilung der bisherigen Items durch 30 null ergibt, erhöhen wir die
	# Blockvariable um 1 (also bei 30, 60, 90, ...)
	var.Block += 1 if exp.items["trial_sequence"].count % 30 == 0 else 0
	__end__
	set _prepare ""

