define sketchpad fixation
	set duration 500
	set description "Displays stimuli"
	draw line color=white penwidth=3 show_if=True x1=-32 x2=32 y1=0 y2=0 z_index=0
	draw line color="#ffffff" penwidth=3 show_if=True x1=0 x2=0 y1=-32 y2=32 z_index=0

define sketchpad instructions
	set duration 0
	set description "Displays stimuli"
	draw textline center=1 color=white font_bold=no font_family=mono font_italic=no font_size=30 html=yes show_if=True text="Welcome to this experiment.<br /><br />You will be presented with strings of letters on the screen. Your task is to decide whether they are existing English words or not.<br /><br />Please respond as quickly as possible:<br />Is it a real word? → Press J.<br />Is it not a real word? → Press F.<br /><br />If you are sure that the word exists, but you don't know its exact meaning, you may still press J. But if you are not sure it is an existing word, you should press F.<br /><br />First, you will complete a small practice run to help understand the task. Press the space bar to start." x=0 y=0 z_index=0

define keyboard_response instructions_keyboard_response
	set timeout infinite
	set flush yes
	set event_type keypress
	set duration keypress
	set description "Collects keyboard responses"
	set allowed_responses space

define logger logger
	set description "Logs experimental data"
	set auto_log yes

define reset_feedback new_1_reset_feedback
	set description "A very simple plug-in to reset feedback variables"

define reset_feedback new_reset_feedback
	set description "A very simple plug-in to reset feedback variables"

define inline_script participants
	set description "Executes Python code"
	___run__
	var.Participant = var.subject_nr
	
	# intialisiere die Variable "Block",
	# setze sie auf null für practice items,
	# danach wird diese die Experimentblöcke 1-6 zählen
	var.Block = 0
	__end__
	set _prepare ""

