---
API: 3
OpenSesame: 4.1.9
Platform: nt
---
set width 1920
set uniform_coordinates yes
set title LDT
set subject_parity even
set subject_nr 0
set start experiment
set sound_sample_size -16
set sound_freq 48000
set sound_channels 2
set sound_buf_size 1024
set sampler_backend legacy
set round_decimals 2
set mouse_backend xpyriment
set keyboard_backend legacy
set height 1010
set fullscreen no
set form_clicks no
set foreground white
set font_underline no
set font_size 18
set font_italic no
set font_family mono
set font_bold no
set experiment_path "C:\\Users\\jasmi\\Documents\\Master\\2_SS26\\Sprache, Emotion und Kognition\\Project\\experiment"
set disable_garbage_collection yes
set description "The main experiment item"
set coordinates uniform
set compensation 0
set color_backend legacy
set clock_backend legacy
set canvas_backend xpyriment
set background black

define sketchpad Datenschutz
	set duration 0
	set description "Displays stimuli"
	draw textline center=1 color=white font_bold=no font_family=mono font_italic=no font_size=35 html=yes show_if=always text="Thank you for your participation. Before starting, please read the following data protection information carefully and confirm your agreement:<br /><br />Anonymization: All your data (questionnaire, LEXTale test, reaction times, and accuracy) will be treated with strict confidentiality. Storage and evaluation will be carried out exclusively in pseudonymized form (e.g., under a code number such as 1001). It will not be possible to identify you personally in the subsequent analysis.<br /><br />Purpose of Use: The collected data will be used exclusively for scientific purposes within the framework of this seminar project. Commercial use or disclosure to third parties is prohibited.<br /><br />Voluntariness & Right to Withdraw: Your participation is entirely voluntary. You have the right to withdraw from the experiment at any time and without giving reasons, without incurring any disadvantages. In the event of withdrawal, your data collected up to that point will be deleted.<br /><br />By continuing the experiment, you confirm that you have read and understood this information and agree to the anonymous processing of your data.<br />Press Space to continue." x=0 y=0 z_index=0

define keyboard_response Datenschutz_keyboard_response
	set timeout infinite
	set flush yes
	set event_type keypress
	set duration keypress
	set description "Collects keyboard responses"
	set allowed_responses space

define sketchpad break_1
	set duration 0
	set description "Displays stimuli"
	draw textline center=1 color=white font_bold=no font_family=mono font_italic=no font_size=50 html=yes show_if=always text="You have completed the first part of the experiment!<br /><br /><br />Take a break until you feel ready to continue.<br />Press Space to complete the rest of the experiment." x=6 y=-16 z_index=0

define sketchpad break_1_1
	set duration 0
	set description "Displays stimuli"
	draw textline center=1 color=white font_bold=no font_family=mono font_italic=no font_size=50 html=yes show_if=always text="You have conplete part of the experiment!<br />Take a break please until you think you are ready to continue.<br />Press Space to complete the rest of the experiment." x=6 y=-16 z_index=0

define keyboard_response break_1_keyboard_response
	set timeout infinite
	set flush yes
	set event_type keypress
	set duration keypress
	set description "Collects keyboard responses"
	set allowed_responses space

define keyboard_response break_1_keyboard_response_1
	set timeout infinite
	set flush yes
	set event_type keypress
	set duration keypress
	set description "Collects keyboard responses"
	set allowed_responses space

define keyboard_response break_2_keyboard_response
	set timeout infinite
	set flush yes
	set event_type keypress
	set duration keypress
	set description "Collects keyboard responses"
	set allowed_responses space

define keyboard_response break_2_keyboard_response_1
	set timeout infinite
	set flush yes
	set event_type keypress
	set duration keypress
	set description "Collects keyboard responses"
	set allowed_responses space

define sketchpad break_2_sketchpad
	set duration 0
	set description "Displays stimuli"
	draw textline center=1 color=white font_bold=no font_family=mono font_italic=no font_size=50 html=yes show_if=always text="You have completed the second part of the experiment!<br /><br /><br />Take a break until you feel ready to continue.<br />Press Space to complete the rest of the experiment." x=6 y=-16 z_index=0

define sketchpad break_2_sketchpad_1
	set duration 0
	set description "Displays stimuli"
	draw textline center=1 color=white font_bold=no font_family=mono font_italic=no font_size=50 html=yes show_if=always text="You have conplete part of the experiment!<br />Take a break please until you think you are ready to continue.<br />Press Space to complete the rest of the experiment." x=0 y=0 z_index=0

define sketchpad end_of_exp
	set duration 0
	set description "Displays stimuli"
	draw textline center=1 color=white font_bold=no font_family=mono font_italic=no font_size=50 html=yes show_if=always text="Thank You!<br /><br />You have completed the experiment. <br />Please press Space to end this experimnet.<br />Thank you very much for your participation!" x=0 y=0 z_index=0

define keyboard_response end_of_exp_keyboard_response
	set timeout infinite
	set flush yes
	set event_type keypress
	set duration keypress
	set description "Collects keyboard responses"
	set allowed_responses space

define sketchpad end_of_prac
	set duration 0
	set description "Displays stimuli"
	draw textline center=1 color=white font_bold=no font_family=mono font_italic=no font_size=50 html=yes show_if=always text="This is the end of the practice.<br /><br /><br />Now let's begin our experiment!<br />Please press Space to start." x=0 y=0 z_index=0

define keyboard_response end_of_prac_keyboard_response
	set timeout infinite
	set flush yes
	set event_type keypress
	set duration keypress
	set description "Collects keyboard responses"
	set allowed_responses space

define sequence experiment
	set flush_keyboard yes
	set description "Runs a number of items in sequence"
	run participants always
	run instructions always
	run instructions_keyboard_response always
	run practice_loop always
	run end_of_prac always
	run end_of_prac_keyboard_response always
	run experimental_loop always
	run end_of_exp always
	run end_of_exp_keyboard_response always

define loop experimental_loop
	set source_file ""
	set source table
	set repeat 1
	set order random
	set description "Repeatedly runs another item"
