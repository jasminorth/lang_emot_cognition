define sketchpad stimulus
	set duration 0
	set description "Displays stimuli"
	draw textline center=1 color=white font_bold=no font_family=mono font_italic=no font_size=100 html=yes show_if=always text="[Stimulus]" x=0 y=0 z_index=0

define sketchpad stimulus_1
	set duration 0
	set description "Displays stimuli"
	draw textline center=1 color=white font_bold=no font_family=mono font_italic=no font_size=100 html=yes show_if=always text="[Stimulus]" x=0 y=0 z_index=0

define keyboard_response stimulus_keyboard_response
	set timeout 2500
	set flush yes
	set event_type keypress
	set duration keypress
	set description "Collects keyboard responses"
	set allowed_responses "j;f"

define keyboard_response stimulus_keyboard_response_1
	set timeout 2500
	set flush yes
	set event_type keypress
	set duration keypress
	set description "Collects keyboard responses"
	set allowed_responses "j;f"

define sequence trial_sequence
	set flush_keyboard yes
	set description "Runs a number of items in sequence"
	run fixation always
	run stimulus always
	run stimulus_keyboard_response always
	run variables always
	run logger always
	run break_1 "[count_trial_sequence] = 59"
	run break_1_keyboard_response "[count_trial_sequence] = 59"
	run break_2_sketchpad "[count_trial_sequence] = 119"
	run break_2_keyboard_response "[count_trial_sequence] = 119"

define sequence trial_sequence_1
	set flush_keyboard yes
	set description "Runs a number of items in sequence"
	run fixation_1 always
	run stimulus_1 always
	run stimulus_keyboard_response_1 always
	run variables_1 always
	run logger_1 always
	run break_1_1 "[count_trial_sequence] = 59"
	run break_1_keyboard_response_1 "[count_trial_sequence] = 59"
	run break_2_sketchpad_1 "[count_trial_sequence] = 119"
	run break_2_keyboard_response_1 "[count_trial_sequence] = 119"

define inline_script variables
	set description "Executes Python code"
	___run__
	var.RT = var.response_time_stimulus_keyboard_response 
	var.Accuracy = var.correct
	__end__
	set _prepare ""

define inline_script variables_1
	set description "Executes Python code"
	___run__
	var.RT = var.response_time_stimulus_keyboard_response 
	var.Accuracy = var.correct
	__end__
	set _prepare ""

define sketchpad welcome
	set start_response_interval no
	set reset_variables no
	set duration keypress
	set description "Displays stimuli"
	draw textline center=1 color=white font_bold=no font_family=serif font_italic=no font_size=32 html=yes show_if=always text="OpenSesame 3.3 <i>Lentiform Loewenfeld</i>" x=0 y=0 z_index=0

